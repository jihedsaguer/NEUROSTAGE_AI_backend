# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=neuro_admin
DB_PASSWORD=neuro_password
DB_NAME=neurostage_db

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=1h

# ─── CORS ─────────────────────────────────────────────────────────────────────
# In Docker / production set to the public frontend origin (e.g. http://localhost or https://yourdomain.com)
CORS_ORIGIN=http://localhost:5173

# ─── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:3000/uploads

# ─── AI microservice ──────────────────────────────────────────────────────────
AI_SERVICE_URL=http://neurostage_ai:8001
# Must be a strong random string shared between NestJS and FastAPI
INTERNAL_SECRET=generate_a_random_32_char_string

# ─── SMTP (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
